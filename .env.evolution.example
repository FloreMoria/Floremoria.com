# =============================================================================
# Evolution API — Template variabili d'ambiente per FloreMoria WhatsApp Gateway
# =============================================================================
# ISTRUZIONI:
#   1. Copia questo file sulla VPS: cp .env.evolution.example .env.evolution
#   2. Compila tutti i valori tra < > con i tuoi dati reali
#   3. NON committare il file .env.evolution (già in .gitignore)
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
# URL pubblico della VPS (raggiungibile da internet — usato da WhatsApp per i media)
# Esempio con IP:     http://123.456.789.0:8080
# Esempio con dominio (consigliato con Nginx+SSL): https://wa-api.floremoria.com
SERVER_URL=http://<IP_PUBBLICO_VPS>:8080

NODE_ENV=production
LOG_LEVEL=ERROR
LOG_COLOR=false

# ─── Sicurezza — API Key ─────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
# QUESTA CHIAVE va copiata su Vercel come variabile EVOLUTION_API_KEY
AUTHENTICATION_API_KEY=<GENERA_CON_OPENSSL_RAND_HEX_32>

# ─── Database Postgres (locale nel container) ─────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:floremoria_evo_pw@evolution-postgres:5432/evolution_db?schema=public
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# Password Postgres (deve coincidere con POSTGRES_PASSWORD nel docker-compose)
EVO_POSTGRES_PASSWORD=floremoria_evo_pw

# ─── Cache Redis (locale nel container) ───────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379
CACHE_REDIS_PREFIX_KEY=evo_floremoria
CACHE_REDIS_SAVE_INSTANCES=true

# ─── Webhook verso FloreMoria (Vercel Production) ────────────────────────────
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=https://www.floremoria.com/api/whatsapp/webhook
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Header di autenticazione: deve coincidere ESATTAMENTE con WHATSAPP_WEBHOOK_SECRET su Vercel
# Genera con: openssl rand -hex 32
WEBHOOK_GLOBAL_HEADERS={"Authorization":"Bearer <GENERA_CON_OPENSSL_RAND_HEX_32_STESSO_DI_VERCEL>"}

# ─── Filtro eventi webhook (solo messaggi in entrata — minimizza traffico) ────
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=false
WEBHOOK_EVENTS_MESSAGES_SET=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=false
WEBHOOK_EVENTS_MESSAGES_DELETE=false
WEBHOOK_EVENTS_SEND_MESSAGE=false
WEBHOOK_EVENTS_CONTACTS_SET=false
WEBHOOK_EVENTS_CONTACTS_UPSERT=false
WEBHOOK_EVENTS_CONTACTS_UPDATE=false
WEBHOOK_EVENTS_PRESENCE_UPDATE=false
WEBHOOK_EVENTS_CHATS_SET=false
WEBHOOK_EVENTS_CHATS_UPSERT=false
WEBHOOK_EVENTS_CHATS_UPDATE=false
WEBHOOK_EVENTS_CHATS_DELETE=false
WEBHOOK_EVENTS_GROUPS_UPSERT=false
WEBHOOK_EVENTS_GROUP_UPDATE=false
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=false
WEBHOOK_EVENTS_CALL=false
WEBHOOK_EVENTS_NEW_JWT_TOKEN=false
WEBHOOK_EVENTS_ERRORS=false

# ─── Istanza WhatsApp ─────────────────────────────────────────────────────────
DEL_INSTANCE=false
QRCODE_LIMIT=30
QRCODE_COLOR=#198754

# Identificativo del client WhatsApp (appare nelle sessioni collegate)
CONFIG_SESSION_PHONE_CLIENT=FloreMoria
CONFIG_SESSION_PHONE_NAME=Chrome
