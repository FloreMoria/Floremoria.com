# Copia queste righe in .env o .env.local (non committare segreti reali).
#
# Sul Mac: host = localhost (porta 5432 mappata da Docker).
# Dentro il container "web": host = db (rete interna compose).
#
DATABASE_URL="postgresql://floremoria:floremoria_pw@localhost:5432/floremoria?schema=public"

# --- Partnership / handoff (API `POST /api/external/order-data`) ---
# Opzionale (legacy): un solo Bearer condiviso. Preferisci credenziali per-partner da Dashboard → API Partner.
# PARTNER_INBOUND_API_SECRET=""

# Origini consentite per chiamate POST dal browser del partner (CSV). In sviluppo non serve (* implicito).
# In produzione es.: "https://www.agenzia-esempio.it,https://checkout.agenzia-esempio.it"
# PARTNER_INBOUND_CORS_ORIGIN="https://www.tuopartner.it"

# --- Stripe webhook (pagamento completato → ordine PAID + email ordini@ + BCC contabile@) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=whsec_...   # Dashboard Stripe → Webhook → firma
# NEXT_PUBLIC_BASE_URL=https://www.floremoria.com

# --- Email transazionale (scegli UNA tra Resend e SMTP) ---
# Mittente (From) per mail a cliente e staff — es. account Google Workspace verificato:
# FLOREM_MAIL_FROM="FloreMoria <assistenza@floremoria.com>"
# FLOREM_MAIL_REPLY_TO="assistenza@floremoria.com"
# FLOREM_STAFF_ORDERS_EMAIL="ordini@floremoria.com"
# FLOREM_STAFF_ACCOUNTING_EMAIL="contabile@floremoria.com"
# Opzionale: BCC sulla mail di conferma al cliente (lascia vuoto per evitare duplicati)
# FLOREM_CUSTOMER_RECEIPT_BCC=

# Opzione A — Resend (API, dominio verificato su resend.com)
# RESEND_API_KEY=re_...

# Opzione B — SMTP (es. Aruba / Google Workspace)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=assistenza@floremoria.com
# SMTP_PASS=app-password
