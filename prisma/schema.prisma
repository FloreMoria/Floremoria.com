generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Ruolo di sistema elevato (promozione solo via `scripts/master-key.ts`).
enum UserRole {
  USER
  OPERATOR
  FLORIST
  AGENCY
  MUNICIPALITY
  ACCOUNTANT
  STAKEHOLDER
  ADMIN
  SUPER_ADMIN
  // Valori legacy mantenuti per retrocompatibilità: esistono già nel DB di produzione.
  // Rimuoverli renderebbe il diff distruttivo (Postgres non sa droppare un valore enum).
  MARKETING_MANAGER
  PARTNER_FLORIST
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id              String          @id @default(cuid())
  uniqueCode      String?         @unique // Codice parlante UT- (es. UT-LOM-BG-001)
  email           String          @unique
  name            String?
  roleId          String?
  /**
   * Elevazione Super Admin: impostabile solo dallo script offline master-key.
   */
  systemRole      UserRole        @default(USER) @map("system_role")
  company         String?
  phone           String?
  vatNumber       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  roleExpiresAt   DateTime?
  deletedAt       DateTime?
  passwordHash    String?         @map("password_hash")
  isActive        Boolean         @default(false) @map("is_active")
  invitationToken String?         @unique @map("invitation_token")
  inviteExpiresAt DateTime?       @map("invite_expires_at")
  lastLoginAt     DateTime?       @map("last_login_at")
  avatarUrl       String?         @map("avatar_url")
  orders          Order[]
  role            Role?           @relation(fields: [roleId], references: [id])
  confirmedProofs DeliveryProof[]
  /** Relazione M2M con profili defunto (più parenti → stesso defunto). */
  deceasedLinks   UserDeceasedLink[]
}

/**
 * Entità dominio «Defunto» (profilo commemorativo condiviso tra parenti e fioristi).
 * Nome tabella storico: DeceasedProfile.
 */
model DeceasedProfile {
  id            String   @id @default(cuid())
  uniqueCode    String?  @unique
  fullName      String
  cemeteryCity  String
  cemeteryName  String?
  verifiedNotes String?  @db.Text
  photoUrl      String?  @map("photo_url")
  orders        Order[]
  userLinks     UserDeceasedLink[]
  partnerLinks  PartnerDeceasedAssignment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Pivot User ↔ Defunto (DeceasedProfile): più utenti possono seguire lo stesso defunto.
model UserDeceasedLink {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  deceasedProfileId String          @map("deceased_profile_id")
  relationship      String?         @db.VarChar(80)
  createdAt         DateTime        @default(now()) @map("created_at")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deceasedProfile   DeceasedProfile @relation(fields: [deceasedProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, deceasedProfileId])
  @@index([deceasedProfileId])
  @@map("user_deceased_links")
}

/// Pivot Fiorista (Partner) ↔ Defunto: custode floreale di zona/tomba.
model PartnerDeceasedAssignment {
  id                String          @id @default(cuid())
  partnerId         String          @map("partner_id")
  deceasedProfileId String          @map("deceased_profile_id")
  isPrimary         Boolean         @default(true) @map("is_primary")
  createdAt         DateTime        @default(now()) @map("created_at")
  partner           Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  deceasedProfile   DeceasedProfile @relation(fields: [deceasedProfileId], references: [id], onDelete: Cascade)

  @@unique([partnerId, deceasedProfileId])
  @@index([deceasedProfileId])
  @@map("partner_deceased_assignments")
}

model Order {
  id                     String            @id @default(cuid())
  status                 OrderStatus       @default(PENDING)
  userId                 String?
  deceasedName           String
  deceasedBirthDate      DateTime?
  deceasedDeathDate      DateTime?
  cemeteryName           String
  cemeteryCity           String
  gravePosition          String?
  deliveryDate           DateTime?
  totalPriceCents        Int
  currency               String            @default("EUR")
  photos                 String[]          @default([])
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  customerPhone          String?
  ticketMessage          String?
  buyerCity              String?
  buyerCountry           String?
  buyerFullName          String?
  buyerEmail             String?
  isRecurring            Boolean           @default(false)
  deletedAt              DateTime?
  additionalInstructions String?
  funeralDate            DateTime?
  latitude               Float?
  longitude              Float?
  partnerId              String?
  /**
   * Ragione sociale o nome agenzia lato partner (AnnunciFunebri / integrazioni B2B).
   */
  agencyName             String?           @map("agency_name") @db.VarChar(255)
  /**
   * Email azienda partner (handoff da siti esterni) per notifiche / rendicontazione.
   */
  partnerNotifyEmail     String?           @map("partner_notify_email") @db.VarChar(255)
  partnerPaymentStatus   PaymentStatus     @default(UNPAID)
  orderNumber            String?           @unique
  deliveryProvince       String?           @db.VarChar(2)
  /** Codice corto per link WhatsApp post-consegna (/f/{code}). */
  proofFotoCode          String?           @unique @map("proof_foto_code") @db.VarChar(10)
  proofFotoExpiresAt     DateTime?         @map("proof_foto_expires_at")
  deceasedProfileId      String?
  deceasedProfile        DeceasedProfile?  @relation(fields: [deceasedProfileId], references: [id])
  partner                Partner?          @relation(fields: [partnerId], references: [id])
  user                   User?             @relation(fields: [userId], references: [id])
  items                  OrderItem[]
  offerRedemptions       OfferRedemption[]
  deliveryProof          DeliveryProof?
  memoryGardenOpens      MemoryGardenOpen[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int     @default(1)
  priceCents Int
  order      Order   @relation(fields: [orderId], references: [id])
  product    Product @relation(fields: [productId], references: [id])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]
}

model Product {
  id               String         @id @default(cuid())
  categoryId       String
  name             String
  slug             String         @unique
  shortDescription String?
  description      String?
  basePriceCents   Int
  currency         String         @default("EUR")
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isBouquet        Boolean        @default(true)
  mediaUrl         String?
  deletedAt        DateTime?
  orderItems       OrderItem[]
  category         Category       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
}

model Offer {
  id          String            @id @default(cuid())
  name        String
  code        String?           @unique
  type        OfferType
  value       Int
  maxUses     Int?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean           @default(true)
  rulesJson   Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  redemptions OfferRedemption[]
}

model OfferRedemption {
  id            String   @id @default(cuid())
  offerId       String
  orderId       String
  buyerEmail    String?
  buyerFullName String?
  usedAt        DateTime @default(now())
  offer         Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([offerId, usedAt])
  @@index([buyerEmail])
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean   @default(false)
  aiGenerated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model NewsletterLog {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

model Partner {
  id              String                  @id @default(cuid())
  coverageArea    String?
  address         String?
  activeOrders    Int                     @default(0)
  adminRating     Float                   @default(5.0)
  internalNotes   String?
  isActive        Boolean                 @default(true)
  isB2B           Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  iban            String?
  whatsappNumber  String?
  deletedAt       DateTime?
  email           String?
  pecAddress      String?
  sdiCode         String?
  taxCode         String?
  vatNumber       String?
  ownerName       String
  shopName        String
  paymentStatus   PaymentStatus           @default(UNPAID)
  province        String?                 @db.VarChar(2)
  uniqueCode      String?                 @unique
  orders          Order[]
  deliveryProofs  DeliveryProof[]
  handoffSessions PartnerHandoffSession[]
  apiCredentials  PartnerApiCredential[]
  deceasedAssignments PartnerDeceasedAssignment[]
}

/**
 * Dati inviati da siti partner (API legacy `order-data`); scambio via `externalKey` in query su checkout.
 */
model PartnerHandoffSession {
  id          String   @id @default(cuid())
  externalKey String   @unique @map("external_key") @db.VarChar(64)
  payload     Json
  expiresAt   DateTime @map("expires_at")
  partnerId   String?  @map("partner_id")
  partner     Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("partner_handoff_sessions")
}

/**
 * Credenziali API per `POST /api/external/order-data` senza variabili Vercel (chiave pubblica + segreto).
 */
model PartnerApiCredential {
  id         String    @id @default(cuid())
  partnerId  String    @map("partner_id")
  partner    Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  label      String
  publicId   String    @unique @map("public_id") @db.VarChar(80)
  secretHash String    @map("secret_hash") @db.Text
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@index([partnerId])
  @@map("partner_api_credentials")
}

model Supplier {
  id            String            @id @default(cuid())
  companyName   String
  category      String
  contactName   String?
  vatNumber     String?
  taxCode       String?
  sdiCode       String?
  pecAddress    String?
  iban          String?
  paypalEmail   String?
  internalNotes String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  email         String?
  phone         String?
  paymentStatus PaymentStatus     @default(UNPAID)
  uniqueCode    String?           @unique
  invoices      SupplierInvoice[]
}

model SupplierInvoice {
  id             String        @id @default(cuid())
  supplierId     String
  invoiceNumber  String
  invoiceDate    DateTime
  reason         String
  amount         Decimal
  paymentDetails String?
  status         PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  supplier       Supplier      @relation(fields: [supplierId], references: [id])
}

model FloremoriaLog {
  id              Int                      @id @default(autoincrement())
  sessionDate     DateTime                 @default(now()) @map("data_sessione") @db.Date
  tag             String?                  @db.VarChar(50)
  topic           String?                  @map("titolo_argomento") @db.VarChar(255)
  keyPrompt       String?                  @map("prompt_chiave") @db.Text
  shortSummary    String?                  @map("riassunto_breve") @db.Text
  searchVector    Unsupported("tsvector")? @map("search_vector")
  criticalAlarms  String?                  @map("allarmi_critici") @db.Text
  pendingTasks    String?                  @map("in_completamento") @db.Text
  discussedPoints String?                  @map("punti_discussi") @db.Text
  achievedResults String?                  @map("risultati_raggiunti") @db.Text
  fullText        String?                  @map("testo_integrale") @db.Text

  @@map("floremoria_logs")
}

/** Mittenti email esclusi dal risponditore automatico assistenza@ (spam, newsletter, robot). */
model EmailBlacklist {
  id        String   @id @default(cuid())
  email     String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_blacklist")
}

/**
 * Numeri di telefono WhatsApp bloccati dal risponditore automatico VERA.
 * Formato atteso: E.164 senza prefisso «whatsapp:», es. "+393204105305".
 * La logica di controllo vive in /api/whatsapp/webhook.
 */
model PhoneBlacklist {
  id        String   @id @default(cuid())
  phone     String   @unique @db.VarChar(30)
  note      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("phone_blacklist")
}

model WhatsAppChatSession {
  id         String               @id @default(cuid())
  phone      String               @unique
  name       String
  userType   String               @default("UNKNOWN")
  status     String               @default("AI_ACTIVE")
  welcomeSent Boolean             @default(false) @map("welcome_sent")
  lastMessage String              @default("") @map("last_message")
  hasPhoto   Boolean              @default(false) @map("has_photo")
  dateLabel  String               @default("oggi") @map("date_label")
  timeLabel  String               @default("") @map("time_label")
  initials   String               @default("UT")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  messages   WhatsAppChatMessage[]

  @@map("whatsapp_chat_sessions")
}

model WhatsAppChatMessage {
  id             String             @id @default(cuid())
  sessionId      String             @map("session_id")
  direction      String
  body           String
  mediaUrl       String?            @map("media_url")
  metadata       Json?
  timestampLabel String             @map("timestamp_label")
  createdAt      DateTime           @default(now()) @map("created_at")
  session        WhatsAppChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("whatsapp_chat_messages")
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELIVERING
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
}

enum OfferType {
  PERCENT
  FIXED
}

model DeliveryProof {
  id              String              @id @default(cuid())
  orderId         String              @unique
  partnerId       String
  userId          String?
  photoBeforeUrl  String?
  photoAfterUrl   String?
  photosBeforeUrls String[]           @default([]) @map("photos_before_urls")
  photosAfterUrls  String[]           @default([]) @map("photos_after_urls")
  timestampBefore DateTime?
  timestampAfter  DateTime?
  gpsLatitude     Float?
  gpsLongitude    Float?
  status          DeliveryProofStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  order   Order   @relation(fields: [orderId], references: [id])
  partner Partner @relation(fields: [partnerId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

enum DeliveryProofStatus {
  PENDING
  BEFORE_UPLOADED
  COMPLETED
}

model MemoryGardenOpen {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  buyerEmail String?  @map("buyer_email")
  buyerName  String?  @map("buyer_name")
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  openedAt   DateTime @default(now()) @map("opened_at")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("memory_garden_opens")
}
