# =============================================================================
# FloreMoria — template variabili d’ambiente (VPS / CI)
# Copia in `.env` o `.env.production` sul server e compila i valori. Non committare segreti.
# =============================================================================

# --- Database ---
DATABASE_URL=

# --- URL pubblici (Next.js, Stripe redirect, sitemap) ---
# Origine del sito in produzione (senza slash finale), es. https://www.floremoria.com
NEXT_PUBLIC_BASE_URL=
# Opzionale: canonical / sitemap (se vuoto in codice può esserci un default legacy)
NEXT_PUBLIC_SITE_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
# Chiave pubblica (Checkout Elements / future integrazioni client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Segreto firma webhook: Dashboard → Developers → Webhooks → endpoint
# POST https://TUO_DOMINIO/api/webhooks/stripe  (evento: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=

# --- Partner / handoff API (`POST /api/external/order-data`) ---
# Legacy: un solo Bearer condiviso (opzionale se usi solo credenziali dashboard per-partner)
PARTNER_INBOUND_API_SECRET=
# Origini CORS consentite (CSV), es. https://www.partner.it — in dev spesso non serve
PARTNER_INBOUND_CORS_ORIGIN=

# --- Integrazioni opzionali ---
# Google Maps (checkout / indirizzi)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Recensioni Google (homepage o widget)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# Google Analytics 4 (dashboard server)
GA4_PROPERTY_ID=
# GA4 / Measurement ID esposto al client (testi dashboard)
NEXT_PUBLIC_GA4_PROPERTY_ID=
# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Webhook interni (es. aggiornamento log)
FLOREMORIA_WEBHOOK_KEY=
# API amministrative protette
ADMIN_API_KEY=

# --- Email ordine (dopo pagamento Stripe) ---
# Mittente (deve essere un indirizzo che il provider consente di usare in SMTP/Resend)
FLOREM_MAIL_FROM="FloreMoria <assistenza@floremoria.com>"
FLOREM_MAIL_REPLY_TO=assistenza@floremoria.com
# Notifica interna: nuovo ordine pagato
FLOREM_STAFF_ORDERS_EMAIL=ordini@floremoria.com
# BCC sulla stessa mail staff (ricevute contabili / copia Stripe-like interna)
FLOREM_STAFF_ACCOUNTING_EMAIL=contabile@floremoria.com
# Opzionale: BCC sulla mail di conferma inviata al cliente (vuoto = nessun BCC extra)
# FLOREM_CUSTOMER_RECEIPT_BCC=
#
# Invio: imposta RESEND_API_KEY *oppure* SMTP_* (vedi env.host.docker.example).
# Ricevute ufficiali Stripe/PayPal in copia a contabile@: si configurano nei rispettivi pannelli
# (Stripe: impostazioni business / email di supporto; PayPal: notifiche account), non solo via .env.

# --- Iubenda / policy (footer) ---
# Se impostati, Privacy e Cookie nel footer puntano a questi URL (es. documenti Iubenda).
# Se vuoti, restano le pagine interne `/privacy` e `/cookie` (placeholder per embed).
NEXT_PUBLIC_LEGAL_PRIVACY_URL=
NEXT_PUBLIC_LEGAL_COOKIE_URL=

# --- Script / tooling (opzionale, non richiesti dal runtime Next) ---
# OPENAI_API_KEY=
# VERBALE_FORCE_ISO=
