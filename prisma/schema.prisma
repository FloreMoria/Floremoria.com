generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id            String    @id @default(cuid())
  uniqueCode    String?   @unique // Codice parlante UT- (es. UT-LOM-BG-001)
  email         String    @unique
  name          String?
  roleId        String?
  company       String?
  phone         String?
  vatNumber     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  roleExpiresAt DateTime?
  deletedAt       DateTime?
  orders          Order[]
  role            Role?           @relation(fields: [roleId], references: [id])
  confirmedProofs DeliveryProof[]
}

model DeceasedProfile {
  id           String   @id @default(cuid())
  uniqueCode   String?  @unique
  fullName     String
  cemeteryCity String
  cemeteryName String?
  verifiedNotes String? @db.Text
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id                     String        @id @default(cuid())
  status                 OrderStatus   @default(PENDING)
  userId                 String?
  deceasedName           String
  deceasedBirthDate      DateTime?
  deceasedDeathDate      DateTime?
  cemeteryName           String
  cemeteryCity           String
  gravePosition          String?
  deliveryDate           DateTime?
  totalPriceCents        Int
  currency               String        @default("EUR")
  photos                 String[]      @default([])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  customerPhone          String?
  ticketMessage          String?
  buyerCity              String?
  buyerCountry           String?
  buyerFullName          String?
  isRecurring            Boolean       @default(false)
  deletedAt              DateTime?
  additionalInstructions String?
  funeralDate            DateTime?
  latitude               Float?
  longitude              Float?
  partnerId              String?
  partnerPaymentStatus   PaymentStatus @default(UNPAID)
  orderNumber            String?       @unique
  deliveryProvince       String?       @db.VarChar(2)
  deceasedProfileId      String?
  deceasedProfile        DeceasedProfile? @relation(fields: [deceasedProfileId], references: [id])
  partner                Partner?      @relation(fields: [partnerId], references: [id])
  user                   User?         @relation(fields: [userId], references: [id])
  items                  OrderItem[]
  deliveryProof          DeliveryProof?
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int     @default(1)
  priceCents Int
  order      Order   @relation(fields: [orderId], references: [id])
  product    Product @relation(fields: [productId], references: [id])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]
}

model Product {
  id               String         @id @default(cuid())
  categoryId       String
  name             String
  slug             String         @unique
  shortDescription String?
  description      String?
  basePriceCents   Int
  currency         String         @default("EUR")
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isBouquet        Boolean        @default(true)
  mediaUrl         String?
  deletedAt        DateTime?
  orderItems       OrderItem[]
  category         Category       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
}

model Offer {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  type      OfferType
  value     Int
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  rulesJson Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean   @default(false)
  aiGenerated Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model NewsletterLog {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
}

model Partner {
  id             String        @id @default(cuid())
  coverageArea   String?
  address        String?
  activeOrders   Int           @default(0)
  adminRating    Float         @default(5.0)
  internalNotes  String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  iban           String?
  whatsappNumber String?
  deletedAt      DateTime?
  pecAddress     String?
  sdiCode        String?
  taxCode        String?
  vatNumber      String?
  ownerName      String
  shopName       String
  paymentStatus  PaymentStatus @default(UNPAID)
  province       String?       @db.VarChar(2)
  uniqueCode     String?       @unique
  orders         Order[]
  deliveryProofs DeliveryProof[]
}

model Supplier {
  id            String            @id @default(cuid())
  companyName   String
  category      String
  contactName   String?
  vatNumber     String?
  taxCode       String?
  sdiCode       String?
  pecAddress    String?
  iban          String?
  paypalEmail   String?
  internalNotes String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  email         String?
  phone         String?
  paymentStatus PaymentStatus     @default(UNPAID)
  uniqueCode    String?           @unique
  invoices      SupplierInvoice[]
}

model SupplierInvoice {
  id             String        @id @default(cuid())
  supplierId     String
  invoiceNumber  String
  invoiceDate    DateTime
  reason         String
  amount         Decimal
  paymentDetails String?
  status         PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  supplier       Supplier      @relation(fields: [supplierId], references: [id])
}

model FloremoriaLog {
  id              Int                      @id @default(autoincrement())
  sessionDate     DateTime                 @default(now()) @map("data_sessione") @db.Date
  tag             String?                  @db.VarChar(50)
  topic           String?                  @map("titolo_argomento") @db.VarChar(255)
  keyPrompt       String?                  @map("prompt_chiave") @db.Text
  shortSummary    String?                  @map("riassunto_breve") @db.Text
  searchVector    Unsupported("tsvector")? @map("search_vector")
  criticalAlarms  String?                  @map("allarmi_critici") @db.Text
  pendingTasks    String?                  @map("in_completamento") @db.Text
  discussedPoints String?                  @map("punti_discussi") @db.Text
  achievedResults String?                  @map("risultati_raggiunti") @db.Text
  fullText        String?                  @map("testo_integrale") @db.Text

  @@map("floremoria_logs")
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELIVERING
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
}

enum OfferType {
  PERCENT
  FIXED
}
